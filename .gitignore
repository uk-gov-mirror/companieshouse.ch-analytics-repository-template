### VS Code workspace files
# Exclude VS Code workspace settings files (explicitly requested)
*.code-workspace

### Python
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
build/
dist/
wheels/
*.egg-info/

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
.pytest_cache/
htmlcov/
.coverage
.coverage.*
nose2-junit.xml
coverage.xml

# Virtual environments
.venv/
venv/
ENV/
env/
uv.lock
.python-version

# Pyre type checker
.pyre/

### Jupyter Notebooks
# Keep notebook files but ignore checkpoint folders
!*.ipynb
.ipynb_checkpoints/

### SQL
# SQL dumps and runtime generated files
*.sql.gz
*.db
*.sqlite
*.sqlite3

### R
# History and workspace files
.Rhistory
.RData
.Rproj.user/

# R package / build
__RData__/
*.Rproj

### Environment & Secrets
# Common env/config files that should not be committed
.env
config.ini
!init-config/{{cookiecutter.project_slug}}/.env

### Misc
# OS files
Thumbs.db
.DS_Store

